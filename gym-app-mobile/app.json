{
  "expo": {
    "name": "FitForge",
    "slug": "gym-app-mobile",
    "scheme": "fitforge",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0b0d10"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.fitforge.gymapp",
      "adaptiveIcon": {
        "backgroundColor": "#0b0d10"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {},
    "plugins": [
      "expo-router",
      "expo-web-browser"
    ]
  }
}
